# NextAuth
NEXTAUTH_SECRET=your-random-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini API (from Google AI Studio - https://aistudio.google.com/apikey)
# Used for: Audio transcription, fallback summarization
GEMINI_API_KEY=your-gemini-api-key

# OpenRouter API (from https://openrouter.ai/keys)
# Used for: AI Chat, Law Compare, OCR, Summarization
OPENROUTER_API_KEY=your-openrouter-api-key
